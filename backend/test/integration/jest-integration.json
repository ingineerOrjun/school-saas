{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../..",
  "roots": ["<rootDir>/test/integration"],
  "testEnvironment": "node",
  "testRegex": ".integration-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "testTimeout": 60000,
  "maxWorkers": 1
}
