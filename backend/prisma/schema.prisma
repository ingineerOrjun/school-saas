// -----------------------------------------------------------------------------
// Scholaris — Multi-Tenant School Management Schema
// -----------------------------------------------------------------------------
// Every domain entity belongs to a School (the tenant).
// Every tenant-scoped table has an index on schoolId for fast filtering.
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum Role {
  ADMIN
  /// Mid-level academic role. STAFF can manage subjects, exams, and
  /// enter results / attendance for ANY class (no teacher-scope check).
  /// Cannot manage students, fees, users, classes, or teachers — those
  /// stay admin-only.
  STAFF
  TEACHER
  STUDENT
  PARENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

/// Demographic gender for student records. OTHER is a deliberate
/// catch-all so the DB never blocks enrollment over identity edge cases.
enum Gender {
  MALE
  FEMALE
  OTHER
}

/// NEB-style letter grades. Stored codes map to A+, A, B+, B, C+, C, D, NG.
enum LetterGrade {
  A_PLUS
  A
  B_PLUS
  B
  C_PLUS
  C
  D
  NG
}

enum FeeFrequency {
  MONTHLY
  ONE_TIME
}

/// Outcome of an academic session for a single student. Set when
/// promotion runs; immutable history afterwards.
enum StudentSessionStatus {
  PROMOTED
  RETAINED
  /// Withdrew or transferred mid-session — record exists for the
  /// year that was attended, but no class change is applied.
  LEFT
}

enum PaymentMethod {
  CASH
  BANK
  ESEWA
  OTHER
}

// -----------------------------------------------------------------------------
// Tenant
// -----------------------------------------------------------------------------

model School {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  /// Public URL of the school's logo image (PNG/JPG/WebP). Null until
  /// uploaded. Path is served by NestJS at `/uploads/logos/<file>`.
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  students            Student[]
  teachers            Teacher[]
  classes             Class[]
  attendance          Attendance[]
  exams               Exam[]
  subjects            Subject[]
  teachingAssignments TeachingAssignment[]
  feeStructures       FeeStructure[]
  feeAssignments      FeeAssignment[]
  payments               Payment[]
  announcements          Announcement[]
  academicSessions       AcademicSession[]
  studentAcademicRecords StudentAcademicRecord[]

  @@map("schools")
}

// -----------------------------------------------------------------------------
// Auth / Identity
// -----------------------------------------------------------------------------

model User {
  id       String @id @default(uuid()) @db.Uuid
  email    String @unique
  password String
  role     Role   @default(ADMIN)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // 1:1 profile rows (a user is either a teacher or a student, never both)
  student Student?
  teacher Teacher?

  // Audit back-relations. Named explicitly with `relation("…")` because
  // each target model has TWO foreign keys pointing at User
  // (createdById + updatedById) — Prisma needs the disambiguators.
  // Use `@@ignore`-equivalent of "no FK constraint name collisions".
  subjectsCreated     Subject[]      @relation("SubjectCreatedBy")
  subjectsUpdated     Subject[]      @relation("SubjectUpdatedBy")
  examsCreated        Exam[]         @relation("ExamCreatedBy")
  examsUpdated        Exam[]         @relation("ExamUpdatedBy")
  resultsCreated      Result[]       @relation("ResultCreatedBy")
  resultsUpdated      Result[]       @relation("ResultUpdatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([schoolId, role])
  @@map("users")
}

// -----------------------------------------------------------------------------
// Domain profiles
// -----------------------------------------------------------------------------

model Student {
  id        String @id @default(uuid()) @db.Uuid
  firstName String
  lastName  String

  /// Nepal-style Symbol / Roll number. Unique within a school when present;
  /// NULL is allowed so legacy rows stay valid until one is assigned.
  symbolNumber String? @db.VarChar(40)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Optional — young students may not yet have login accounts.
  userId String? @unique @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Optional — students live "in" the school before being assigned to a class.
  // A student can be linked to a class directly when that class has no
  // sections (small schools often skip sections entirely). When a section
  // is set, its classId must equal this student's classId — the service
  // enforces that invariant on create/update.
  classId String? @db.Uuid
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  sectionId String?  @db.Uuid
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  // Demographic + contact essentials required by every real school.
  // gender / dateOfBirth / parentName / contactNumber are NOT NULL and
  // enforced by the DTO layer; the migration backfills sensible
  // placeholders for any rows that pre-date this change.
  gender         Gender
  dateOfBirth    DateTime  @db.Date
  parentName     String    @db.VarChar(120)
  contactNumber  String    @db.VarChar(40)
  /// Optional postal / street address — free-form so it accommodates
  /// any country's format.
  address        String?
  /// Optional admission date — defaults to row createdAt for legacy
  /// rows, but the form lets admins set the real value when known.
  admissionDate  DateTime? @db.Date

  attendance     Attendance[]
  results        Result[]
  feeAssignments FeeAssignment[]
  payments       Payment[]
  academicRecords StudentAcademicRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, symbolNumber])
  @@index([schoolId])
  @@index([classId])
  @@index([sectionId])
  @@map("students")
}

// -----------------------------------------------------------------------------
// Academic hierarchy
// -----------------------------------------------------------------------------

model Class {
  id   String @id @default(uuid()) @db.Uuid
  name String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  sections            Section[]
  students            Student[]
  teachers            Teacher[]
  teachingAssignments TeachingAssignment[]
  feeStructures       FeeStructure[]
  academicRecords     StudentAcademicRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("classes")
}

model Section {
  id   String @id @default(uuid()) @db.Uuid
  name String

  classId String @db.Uuid
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  students            Student[]
  teachers            Teacher[]
  teachingAssignments TeachingAssignment[]
  academicRecords     StudentAcademicRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, name])
  @@index([classId])
  @@map("sections")
}

// -----------------------------------------------------------------------------
// Attendance
// -----------------------------------------------------------------------------

model Attendance {
  id     String           @id @default(uuid()) @db.Uuid
  date   DateTime         @db.Date
  status AttendanceStatus

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Denormalized for fast tenant-scoped queries; kept in sync by the service.
  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// Academic session — defaults to the active session at write
  /// time. Reports filter by this when comparing year-over-year.
  sessionId String?          @db.Uuid
  session   AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@index([schoolId, sessionId, date])
  @@map("attendance")
}

// -----------------------------------------------------------------------------
// Exams + Results (NEB grading system)
// -----------------------------------------------------------------------------

model Exam {
  id   String @id @default(uuid()) @db.Uuid
  name String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  subjects ExamSubject[]
  results  Result[]

  /// Audit. Same nullable + SetNull pattern as Subject — see comment
  /// on Subject for the reasoning.
  createdById String? @db.Uuid
  createdBy   User?   @relation("ExamCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String? @db.Uuid
  updatedBy   User?   @relation("ExamUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  /// Academic session this exam belongs to. Nullable: existing rows
  /// from before the session feature have no session attached. New
  /// writes default to the active session; SetNull on session delete
  /// so removing a session detaches its exams instead of cascading.
  sessionId String?         @db.Uuid
  session   AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([schoolId, sessionId])
  @@map("exams")
}

model ExamSubject {
  id   String @id @default(uuid()) @db.Uuid
  name String
  /// Theory component full marks. Required; defaults to 100 for backward compat.
  theoryFullMarks Int @default(100)
  /// Practical component full marks. 0 means this subject has no practical
  /// (theory-only) and the pass rule auto-passes practical.
  practicalFullMarks Int @default(0)

  examId String @db.Uuid
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  results Result[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, name])
  @@index([examId])
  @@map("exam_subjects")
}

/// One record per (student, subject). Grade data is derived from `marks`
/// server-side via GradingService and stored denormalized for fast reads.
model Result {
  id String @id @default(uuid()) @db.Uuid

  examId String @db.Uuid
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId String      @db.Uuid
  subject   ExamSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  theoryMarks    Float @default(0)
  practicalMarks Float @default(0)
  percentage     Float
  letterGrade    LetterGrade
  gradePoint     Float

  /// Audit. Particularly useful for results since they're often
  /// disputed — knowing which teacher / staff / admin entered or
  /// last edited a mark is important for compliance.
  createdById String? @db.Uuid
  createdBy   User?   @relation("ResultCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String? @db.Uuid
  updatedBy   User?   @relation("ResultUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  /// Academic session — denormalized from the parent Exam so result
  /// queries can filter by session without a join. Set to the exam's
  /// session at insert time; left untouched on later edits.
  sessionId String?          @db.Uuid
  session   AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId])
  @@index([examId])
  @@index([studentId])
  @@index([sessionId])
  @@map("results")
}

model Teacher {
  id   String @id @default(uuid()) @db.Uuid
  name String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// REQUIRED — every Teacher must be linked to a User. The dashboard
  /// resolves a teacher's assignments via Teacher.userId === user.id,
  /// so a userId-less row is unreachable from the teacher's POV.
  /// Enforced at the API layer (createWithUser is the only allowed
  /// path) AND at the DB layer (NOT NULL + cascade on user delete).
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Assigned class. Drives role-based access: a TEACHER user is only
  /// allowed to mark attendance / enter marks for students in this
  /// class. Null when the admin hasn't assigned the teacher anywhere
  /// yet — a teacher with no classId effectively has read-only access.
  classId String? @db.Uuid
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  /// Optional narrower scope. When set, the teacher can ONLY act on
  /// students in this section (a subset of `class`). Useful when one
  /// class has multiple sections taught by different teachers.
  /// The service enforces section.classId === teacher.classId on writes.
  ///
  /// DEPRECATED: superseded by the `teachingAssignments` relation. Kept
  /// on the row so the login flow can still surface a "primary" class
  /// for routing decisions, and so old admin UIs keep working until
  /// they migrate. New permission checks read from TeachingAssignment.
  sectionId String?  @db.Uuid
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  /// Source of truth for what the teacher can act on. Each row pairs
  /// the teacher with a (class, optional section, optional subject).
  /// A teacher can have many — covering multiple classes and/or
  /// multiple subjects.
  assignments TeachingAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([classId])
  @@index([sectionId])
  @@map("teachers")
}

// -----------------------------------------------------------------------------
// Teaching assignments (multi-class / multi-subject)
// -----------------------------------------------------------------------------

/// School-owned subject catalog (Math, Science, English, ...). Subjects
/// are referenced by `TeachingAssignment.subjectId` to express "this
/// teacher teaches Math to Class 8" rather than "this teacher teaches
/// Class 8" alone.
///
/// `ExamSubject` (per-exam subject row with full marks) does NOT yet
/// link to this table — that's a separate migration. For now Subject is
/// only used by TeachingAssignment.
model Subject {
  id   String @id @default(uuid()) @db.Uuid
  name String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  teachingAssignments TeachingAssignment[]

  /// Audit: who originally created this row + who last touched it.
  /// Both nullable: existing rows from before this migration have
  /// no creator on file, and we'd rather keep the row than fabricate
  /// one. SetNull on user delete so removing a teacher/admin doesn't
  /// nuke the subject they once created.
  createdById String? @db.Uuid
  createdBy   User?   @relation("SubjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String? @db.Uuid
  updatedBy   User?   @relation("SubjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}

/// One row per "this teacher can act on this (class, optional section,
/// optional subject)". A teacher with multiple rows covers multiple
/// classes/subjects — exactly the multi-class case the legacy single
/// `Teacher.classId/sectionId` couldn't express.
///
/// Coverage rules used by TeacherScopeService:
///   • sectionId set  → assignment covers ONLY that section
///   • sectionId null → assignment covers the WHOLE class (every
///     section under it + students linked directly to the class)
///   • subjectId set  → required for exam writes (saveResults) on this
///     class. Attendance writes ignore subjectId — they only check class.
///   • subjectId null → "any subject" / "no subject" — used for class
///     teachers, who own attendance but not necessarily a subject.
model TeachingAssignment {
  id String @id @default(uuid()) @db.Uuid

  teacherId String  @db.Uuid
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  classId String @db.Uuid
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  sectionId String?  @db.Uuid
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  subjectId String?  @db.Uuid
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  /// Denormalized for fast tenant-scoped queries + cross-tenant safety.
  /// Always equal to the teacher's schoolId; the service writes both.
  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Postgres treats NULLs as DISTINCT in unique indexes, so duplicate
  /// (teacher, class, NULL section, NULL subject) rows are technically
  /// allowed by this constraint. The service-level guard rejects any
  /// duplicate before insert; this index just protects against truly
  /// identical non-null tuples.
  @@unique([teacherId, classId, sectionId, subjectId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([classId])
  @@index([sectionId])
  @@index([subjectId])
  @@map("teaching_assignments")
}

// -----------------------------------------------------------------------------
// Fees
// -----------------------------------------------------------------------------

model FeeStructure {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  amount    Float
  frequency FeeFrequency

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// Optional class scope. When set, this fee only applies to students
  /// assigned to that class — assigning to any other student is rejected
  /// in the service layer. Null means "applies to any class" (a general
  /// school-wide fee).
  classId String? @db.Uuid
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  assignments FeeAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([classId])
  @@map("fee_structures")
}

model FeeAssignment {
  id String @id @default(uuid()) @db.Uuid
  /// Amount snapshot captured at assignment time. Changes to the parent
  /// FeeStructure do NOT retroactively affect already-assigned fees.
  /// This is the BASE amount — the final amount owed after any discount
  /// is computed as `amount - (PERCENT? amount*value/100 : value)`.
  amount  Float
  dueDate DateTime @db.Date

  /// Scholarship / discount for this specific assignment. Null = no
  /// discount. `discountValue` is a percentage (0–100) when type is
  /// PERCENT, or a currency amount when type is FIXED. The final due
  /// amount is clamped to 0 at the service layer so negative dues are
  /// impossible.
  discountType  DiscountType?
  discountValue Float?

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  feeStructureId String       @db.Uuid
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([dueDate])
  @@map("fee_assignments")
}

enum DiscountType {
  PERCENT
  FIXED
}

model Payment {
  id     String   @id @default(uuid()) @db.Uuid
  amount Float
  date   DateTime @db.Date

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /// Optional link to a specific assignment. Unlinked payments count as a
  /// general credit against the student's total due.
  feeAssignmentId String?        @db.Uuid
  feeAssignment   FeeAssignment? @relation(fields: [feeAssignmentId], references: [id], onDelete: SetNull)

  /// Auto-generated RCPT-YYYY-NNNN. Nullable for pre-receipt-system payments;
  /// unique within a school.
  receiptNumber String? @db.VarChar(40)
  /// Free-form note attached to the receipt (e.g. "Paid in cash by parent").
  notes  String?
  /// How the payment was made. Optional — not every record carries this detail.
  method PaymentMethod?

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, receiptNumber])
  @@index([schoolId])
  @@index([studentId])
  @@index([feeAssignmentId])
  @@map("payments")
}

// -----------------------------------------------------------------------------
// Announcements
// -----------------------------------------------------------------------------

/// School-wide announcement posted by an admin and visible to every
/// authenticated user in that school. Intentionally minimal —
/// title + body + timestamp — so the feature ships small and grows
/// later (audience scoping, attachments, expiry, etc.).
model Announcement {
  id      String @id @default(uuid()) @db.Uuid
  title   String @db.VarChar(160)
  /// Body text. No length cap at the DB level; the DTO enforces a
  /// reasonable max so the UI doesn't have to render walls of text.
  message String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// Optional session scope. Many announcements span sessions
  /// ("Welcome back!" in early-year etc.) so this is purely a
  /// classifier — the announcements feed doesn't filter on it by
  /// default. Defaults to the active session at write time.
  sessionId String?          @db.Uuid
  session   AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Listed newest-first; the (schoolId, createdAt) pair makes the
  // tenant-scoped feed query an index-only seek-and-scan.
  @@index([schoolId, createdAt])
  @@index([schoolId, sessionId])
  @@map("announcements")
}

// -----------------------------------------------------------------------------
// Academic sessions (multi-year support)
// -----------------------------------------------------------------------------

/// One academic year per school. Drives report scoping and the
/// promotion workflow. The "active" flag is the school's current
/// session — exactly one row per school can have it set, enforced by
/// a partial unique index in the migration.
///
/// Existing rows on the four target tables (Exam, Result, Attendance,
/// Announcement) carry sessionId = NULL until explicitly assigned
/// — the queries that filter by session treat NULL as "any session"
/// to keep legacy data visible during the transition.
model AcademicSession {
  id        String   @id @default(uuid()) @db.Uuid
  /// Display label — e.g. "2082/83" or "2024-25". Unique per school.
  name      String   @db.VarChar(40)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean  @default(false)

  /// When true, the session is read-only: attendance writes,
  /// marks updates, and exam edits/creates all reject. Lock is
  /// the precondition for running promotion — admins lock the
  /// year, double-check the books, then run promotion to roll
  /// students into the next session.
  isLocked  Boolean  @default(false)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Children — back-relations for the tables that gain a sessionId.
  // SetNull on session delete (defined on the FK side) for the
  // historical records; cascade for the academic records (those are
  // session-shaped data, no point keeping orphans).
  exams           Exam[]
  results         Result[]
  attendance      Attendance[]
  announcements   Announcement[]
  academicRecords StudentAcademicRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([schoolId, isActive])
  @@map("academic_sessions")
}

/// Per-student per-session history row. Captures the class the
/// student WAS IN during the session (snapshot at promotion time)
/// plus the outcome (promoted / retained / left). Immutable once
/// written — never edited, never deleted (cascade-on-delete only
/// kicks if the parent session/student is removed).
///
/// `(studentId, sessionId)` is unique — exactly one outcome per
/// student per academic year.
model StudentAcademicRecord {
  id String @id @default(uuid()) @db.Uuid

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  sessionId String          @db.Uuid
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// Class the student was in DURING this session. Snapshot — does
  /// NOT update if the class is later renamed (we want the historical
  /// truth, not the current display).
  classId String @db.Uuid
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  /// Optional section snapshot. Null when the school doesn't use
  /// sections or the student wasn't placed in one.
  sectionId String?  @db.Uuid
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  status StudentSessionStatus @default(PROMOTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sessionId])
  @@index([sessionId])
  @@index([classId])
  @@index([schoolId])
  @@map("student_academic_records")
}
