// -----------------------------------------------------------------------------
// Scholaris — Multi-Tenant School Management Schema
// -----------------------------------------------------------------------------
// Every domain entity belongs to a School (the tenant).
// Every tenant-scoped table has an index on schoolId for fast filtering.
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum Role {
  /// Platform owner — bypasses school scoping and accesses the
  /// /platform UI. Created manually via seed; cannot be promoted from
  /// the school admin UI. School admins never see these rows in
  /// their User management list (the service filters them out).
  SUPER_ADMIN
  ADMIN
  /// Mid-level academic role. STAFF can manage subjects, exams, and
  /// enter results / attendance for ANY class (no teacher-scope check).
  /// Cannot manage students, fees, users, classes, or teachers — those
  /// stay admin-only.
  STAFF
  TEACHER
  STUDENT
  PARENT
}

/// Platform-level audit action taxonomy. Phase 8 ships with one
/// action; subsequent platform phases will ADD VALUE for their own
/// (e.g. SCHOOL_CREATED, SUBSCRIPTION_CHANGED, FEATURE_FLAG_CHANGED,
/// IMPERSONATION_STARTED, IMPERSONATION_ENDED, ADMIN_PASSWORD_RESET).
enum PlatformAuditAction {
  SCHOOL_STATUS_CHANGED
  /// SUPER_ADMIN started impersonating a school user (Phase 7).
  /// `target` is the impersonated user; `actor` is the SUPER_ADMIN.
  IMPERSONATION_STARTED
  /// Impersonation session ended — either via the explicit "Exit
  /// impersonation" button or via re-login. Recorded for the
  /// session-duration trail.
  IMPERSONATION_ENDED
  /// New subscription period created for a school (Phase 4). Covers
  /// initial plan creation, renewals, plan changes, and extensions
  /// — all are append-only writes via the same code path.
  SUBSCRIPTION_CREATED
  /// School-level maintenance mode toggled (Phase 17). Soft
  /// read-only gate distinct from SUSPENDED. The before/after JSON
  /// captures the previous + new boolean.
  SCHOOL_MAINTENANCE_TOGGLED
  /// School-level feature override changed (Phase 5). The
  /// `before`/`after` JSON snapshots carry the override map so the
  /// audit row alone tells the full "who turned what on/off" story.
  FEATURE_FLAG_CHANGED
  /// Single user's existing JWTs invalidated (Phase 9). Used when
  /// an operator suspects one account is compromised.
  USER_FORCE_LOGOUT
  /// Every user at a school had their JWTs invalidated (Phase 9).
  /// Heavier hammer than USER_FORCE_LOGOUT — used during incident
  /// response or after a school-wide credential leak.
  SCHOOL_FORCE_LOGOUT
  /// SUPER_ADMIN reset a school user's password (Phase 9). The
  /// plaintext temp password is delivered to the operator via the
  /// API response only; the audit row carries no secret material.
  ADMIN_PASSWORD_RESET
  /// Public school code assigned at school creation. Emitted by
  /// SchoolCodeService whether the code was auto-generated
  /// (SCH-0001 sequence) or manually supplied by a SUPER_ADMIN.
  /// `after` carries the assigned code; `before` is null.
  SCHOOL_CODE_ASSIGNED
  /// Public school code changed by a SUPER_ADMIN after creation.
  /// School admins cannot trigger this — the platform endpoint is
  /// SUPER_ADMIN-gated. `before` / `after` carry the old + new
  /// codes for the audit trail.
  SCHOOL_CODE_UPDATED
  /// School ADMIN locked an exam. After this, every Result write
  /// path (per-student save, bulk save, grid save) rejects with
  /// HTTP 423 LOCKED unless the exam is explicitly unlocked first.
  /// `target` carries the examId; `after.lockedAt` is the lock time.
  MARKS_LOCKED
  /// School ADMIN unlocked an exam, re-enabling marks edits.
  /// `target` carries the examId. Edits performed AFTER unlock
  /// continue to flow through the existing per-result audit path.
  MARKS_UNLOCKED
  /// School-side bulk attendance overwrite (mark all present /
  /// absent for a class on a given day). Surfaced as audit because
  /// it touches every student in the scope at once and is hard to
  /// undo by hand. `after.entryCount` records how many students
  /// were affected.
  ATTENDANCE_BULK_OVERWRITE
  /// Student soft-archived. The row stays in the DB (preserves
  /// foreign-key history on attendance / results / payments) but is
  /// hidden from default listings. `after.archiveReason` records the
  /// free-form reason captured in the dialog.
  STUDENT_ARCHIVED
  /// Student restored from the archive — re-enters default listings.
  /// `before.archiveReason` preserves the historical reason.
  STUDENT_RESTORED
  /// Exam soft-archived. Same semantics as STUDENT_ARCHIVED: rows
  /// remain (Result history is preserved) but the exam no longer
  /// appears in default lists or pickers.
  EXAM_ARCHIVED
  /// Exam restored from the archive.
  EXAM_RESTORED
  /// School ADMIN published an exam — marks become visible on the
  /// parent-facing marksheet. Orthogonal to the lock flag: a
  /// published exam can still be unlocked for further edits.
  /// Phase ACADEMIC TRANSITION SAFETY Part 4 (Draft/Published/Locked).
  MARKS_PUBLISHED
  /// School ADMIN unpublished an exam — marks return to draft state
  /// (parent-facing surfaces hide them again). The marks themselves
  /// are unchanged; only their visibility flips.
  MARKS_UNPUBLISHED
  /// Promotion preview was generated for the school (read-only,
  /// no rows changed). Logged so audits can answer "did anyone
  /// review the year-end roll-forward before pulling the trigger?"
  /// Phase ACADEMIC TRANSITION SAFETY Part 1.
  PROMOTION_PREVIEWED
  /// Promotion run executed — full snapshot landed and the school
  /// rolled into the next session. `after.counts` carries
  /// promoted/retained/left totals, `after.toSessionId` the new
  /// session's id. Phase ACADEMIC TRANSITION SAFETY Part 6.
  PROMOTION_EXECUTED
}

/// Subscription plan tiers (Phase 4). Real billing integration is
/// out of scope for v1 — the platform owner manually records what
/// each school is on. Phase 4.x can wire Stripe / eSewa later.
enum SubscriptionPlan {
  /// Time-limited evaluation. Same access as MONTHLY but flagged
  /// for the "trial expiring" warning + the school's `status` is
  /// auto-set to TRIAL on creation.
  TRIAL
  MONTHLY
  YEARLY
  /// Perpetual access. `endDate` is NULL on UNLIMITED rows.
  UNLIMITED
}

/// Billing cadence. Decoupled from `SubscriptionPlan` because a
/// future MONTHLY plan billed quarterly (or a YEARLY plan billed
/// monthly) is realistic. For v1 they line up 1:1.
enum BillingCycle {
  MONTHLY
  YEARLY
  /// Trials — single payment / one-shot evaluation.
  ONE_TIME
  /// UNLIMITED plans — never billed again.
  PERPETUAL
}

/// Lifecycle status of a school (tenant) on the platform.
///
///   ACTIVE    — paid + healthy. Default for every school today.
///   TRIAL     — limited-time evaluation. Same access as ACTIVE,
///               flagged for the principal banner + platform-side
///               expiry tracking.
///   SUSPENDED — admin-flipped. Users at this school are blocked
///               from logging in until the platform owner reactivates.
///               Existing data preserved untouched.
///   EXPIRED   — subscription ended. Same effect as SUSPENDED today;
///               a future Phase 4 will let the platform owner choose
///               read-only mode instead of full block.
enum SchoolStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  EXPIRED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

/// Demographic gender for student records. OTHER is a deliberate
/// catch-all so the DB never blocks enrollment over identity edge cases.
enum Gender {
  MALE
  FEMALE
  OTHER
}

/// NEB-style letter grades. Stored codes map to A+, A, B+, B, C+, C, D, NG.
enum LetterGrade {
  A_PLUS
  A
  B_PLUS
  B
  C_PLUS
  C
  D
  NG
}

enum FeeFrequency {
  MONTHLY
  ONE_TIME
}

/// Outcome of an academic session for a single student. Set when
/// promotion runs; immutable history afterwards.
enum StudentSessionStatus {
  PROMOTED
  RETAINED
  /// Withdrew or transferred mid-session — record exists for the
  /// year that was attended, but no class change is applied.
  LEFT
}

enum PaymentMethod {
  CASH
  BANK
  ESEWA
  OTHER
}

/// Phase 2 (maturity) — Notification channel taxonomy. Only EMAIL +
/// IN_APP are wired today; SMS + WHATSAPP are reserved so adding
/// them is a code change, not a migration.
enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
  WHATSAPP
}

/// Phase 15 — Job lifecycle states. The runtime worker advances
/// jobs through these; operators read them to triage what's stuck.
///   PENDING   — waiting to be picked up.
///   SCHEDULED — claimed by a worker, will run at runAt.
///   RUNNING   — handler in flight.
///   SUCCEEDED — handler resolved.
///   FAILED    — handler threw and retries are exhausted.
///   DEAD      — operator-killed; no automatic transition.
enum JobStatus {
  PENDING
  SCHEDULED
  RUNNING
  SUCCEEDED
  FAILED
  DEAD
  /// Phase 22 — the dead-letter terminal state. Distinct from FAILED
  /// (which represents a transient single-attempt failure that may
  /// still be retried by the worker) and DEAD (operator-cancelled).
  /// FAILED_PERMANENT means: max attempts exhausted, the runner has
  /// given up. Operator action required. Visible in the Operations
  /// Center "Dead Letter Queue" panel; manually retryable from there.
  FAILED_PERMANENT
}

/// Phase 14 — operator-facing severity tier for Notification Center
/// listing + filtering. Drives chip color + the bell-badge count.
///   INFO     — informational (default).
///   SUCCESS  — completed-action confirmation.
///   WARNING  — attention-required, not blocking.
///   ERROR    — recoverable failure.
///   CRITICAL — production incident, requires immediate attention.
enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
  CRITICAL
}

/// Lifecycle of a single delivery attempt.
///   QUEUED   — created but not yet picked up by a worker / sender.
///   SENDING  — provider call in flight.
///   SENT     — provider acknowledged successful delivery.
///   FAILED   — provider call failed; retries may still be in play.
///   SKIPPED  — delivery was bypassed (channel disabled, user opted
///              out, etc.). Not an error; just a record that we
///              didn't try.
enum NotificationDeliveryStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  SKIPPED
}

// -----------------------------------------------------------------------------
// Tenant
// -----------------------------------------------------------------------------

model School {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  /// Public, human-readable, platform-unique school identifier.
  /// Format: uppercase + digits + dashes only (`^[A-Z0-9-]+$`).
  /// Default generation produces SCH-0001, SCH-0002, …; SUPER_ADMIN
  /// may supply a custom code at creation (KTM-001, EVEREST-01, …)
  /// or change it later via the platform layer.
  ///
  /// Used as the tenant selector on the login form (login is
  /// `schoolCode + email + password`, not just `email + password`),
  /// so two different schools may legitimately have users sharing
  /// an email address — the schoolCode disambiguates.
  ///
  /// Mutable only by SUPER_ADMIN; school admins cannot edit. Every
  /// assignment / change emits a PlatformAuditEvent
  /// (SCHOOL_CODE_ASSIGNED / SCHOOL_CODE_UPDATED).
  schoolCode String   @unique @db.VarChar(40)
  /// Public URL of the school's logo image (PNG/JPG/WebP). Null until
  /// uploaded. Path is served by NestJS at `/uploads/logos/<file>`.
  logoUrl   String?
  /// Free-form postal/street address shown on printable artifacts
  /// (receipts, marksheets, ledgers). Nullable — left blank until the
  /// admin fills it in from Settings.
  address   String?
  /// Public phone number, free-form so country code + format are
  /// admin-controlled. Shown beside the address on receipts.
  phone     String?  @db.VarChar(40)

  /// Public contact email. Used by the platform layer for support
  /// communication and subscription notifications. Optional — pre-
  /// platform schools have no email on file.
  email     String?  @db.VarChar(180)

  /// Lifecycle status. Default ACTIVE; only the platform layer
  /// (SUPER_ADMIN) can mutate this. Login + most write paths reject
  /// when status is SUSPENDED or EXPIRED.
  status    SchoolStatus @default(ACTIVE)

  /// Subscription expiry. Optional today (Phase 4 wires the full
  /// subscription model); a non-null value lets the platform UI
  /// surface "expires in N days" warnings.
  expiresAt DateTime?

  /// Phase 17 — soft read-only flag. When true, the
  /// MaintenanceModeGuard rejects mutating requests (POST / PATCH /
  /// PUT / DELETE) with 503 across every tenant-scoped endpoint.
  /// Reads continue to work; SUPER_ADMIN bypasses the guard so
  /// the operator can finish whatever maintenance prompted the
  /// toggle. Distinct from SUSPENDED — a school can be ACTIVE-and-
  /// in-maintenance during a support session.
  maintenanceMode Boolean @default(false)
  /// Phase 22 — scheduled maintenance window. When `maintenanceScheduledStart`
  /// has passed (and `maintenanceScheduledEnd` hasn't), the
  /// MaintenanceModeService enables `maintenanceMode` automatically.
  /// `maintenanceScheduledEnd` triggers the auto-disable. The
  /// MaintenanceMessage shows in the school-side banner / 503
  /// response so users see operator-authored copy instead of a
  /// generic outage string. All three are nullable — set them
  /// together to schedule, leave them null for ad-hoc toggles.
  maintenanceScheduledStart DateTime?
  maintenanceScheduledEnd   DateTime?
  maintenanceMessage        String?   @db.VarChar(500)

  /// Phase 23 — onboarding wizard progress. `onboardingStep` is a
  /// short slug ("school-profile" | "academic-setup" | "staff-setup"
  /// | "fee-setup" | "complete"); the frontend resumes the wizard
  /// from this step. `onboardingCompleted` flips true when the
  /// wizard finishes (or the operator skips). Used by the dashboard
  /// shell to redirect newly-provisioned tenants into the wizard.
  onboardingCompleted Boolean @default(false)
  onboardingStep      String  @default("school-profile") @db.VarChar(40)

  /// Phase 23 — per-tenant brand customization. All five fields are
  /// nullable; the resolver falls back to the global BrandConfig
  /// (env-driven) for any unset value. Surfaced on receipts /
  /// report cards / login page via the BrandConfig service.
  brandPrimaryColor   String? @db.VarChar(20)
  brandAccentColor    String? @db.VarChar(20)
  brandSlogan         String? @db.VarChar(160)
  brandReceiptFooter  String? @db.VarChar(500)

  /// Phase 5 — per-tenant feature overrides. Keys are feature
  /// catalog entries (see backend/src/feature-flags/feature-catalog.ts);
  /// values are booleans. An entry here OVERRIDES whatever the
  /// current subscription says, in either direction:
  ///
  ///   • { sms: true }   → force SMS on even if the plan disables it.
  ///   • { sms: false }  → force SMS off even if the plan enables it.
  ///
  /// Absent keys fall through to the subscription layer, then to the
  /// default catalog. Default `{}` so legacy schools have no
  /// overrides — they inherit subscription + catalog behaviour.
  featureOverrides Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  students            Student[]
  teachers            Teacher[]
  classes             Class[]
  attendance          Attendance[]
  exams               Exam[]
  subjects            Subject[]
  teachingAssignments TeachingAssignment[]
  feeStructures       FeeStructure[]
  feeAssignments      FeeAssignment[]
  payments               Payment[]
  announcements          Announcement[]
  academicSessions       AcademicSession[]
  studentAcademicRecords StudentAcademicRecord[]
  subscriptions          SchoolSubscription[]
  notifications          Notification[]
  // Phase 23 back-relations
  invitations            UserInvitation[]
  guardians              Guardian[]
  studentGuardianLinks   StudentGuardianLink[]
  supportNotes           SupportNote[]
  dataExportRuns         DataExportRun[]
  importRuns             ImportRun[]
  // CDC continuous-evaluation write surface (Session 3).
  continuousRecords      ContinuousRecord[]
  // CDC portfolio-item write surface (Session 4).
  portfolioItems         PortfolioItem[]

  @@index([status])
  @@map("schools")
}

// -----------------------------------------------------------------------------
// Auth / Identity
// -----------------------------------------------------------------------------

model User {
  id       String @id @default(uuid()) @db.Uuid
  /// Tenant-scoped: unique per (schoolId, email), not globally.
  /// Two different schools are allowed to have users with the same
  /// email address — the login flow disambiguates via the school's
  /// public `schoolCode`. The compound unique index lives on the
  /// model below as `@@unique([schoolId, email])`.
  email    String
  password String
  role     Role   @default(ADMIN)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// Phase 9 — session-invalidation watermark. JWTs whose `iat`
  /// (issued-at) is older than this timestamp are rejected by the
  /// auth strategy, regardless of their `exp`. Null on legacy rows
  /// + on freshly-created users (no revocation point set).
  ///
  /// Set by:
  ///   • SUPER_ADMIN clicking "Force logout" on a user (now()).
  ///   • SUPER_ADMIN clicking "Force logout all" on a school (now()).
  ///   • SUPER_ADMIN resetting an admin's password (now()).
  ///
  /// The user's next successful login issues a fresh JWT whose
  /// `iat` is by definition >= tokensValidAfter, so login-then-
  /// continue works normally. There's no per-token allowlist to
  /// maintain — this is a watermark, not a denylist.
  tokensValidAfter DateTime?

  // 1:1 profile rows (a user is either a teacher or a student, never both)
  student Student?
  teacher Teacher?

  // Audit back-relations. Named explicitly with `relation("…")` because
  // each target model has TWO foreign keys pointing at User
  // (createdById + updatedById) — Prisma needs the disambiguators.
  // Use `@@ignore`-equivalent of "no FK constraint name collisions".
  subjectsCreated     Subject[]      @relation("SubjectCreatedBy")
  subjectsUpdated     Subject[]      @relation("SubjectUpdatedBy")
  examsCreated        Exam[]         @relation("ExamCreatedBy")
  examsUpdated        Exam[]         @relation("ExamUpdatedBy")
  examsLocked         Exam[]         @relation("ExamLockedBy")
  examsArchived       Exam[]         @relation("ExamArchivedBy")
  examsPublished      Exam[]         @relation("ExamPublishedBy")
  studentsArchived    Student[]      @relation("StudentArchivedBy")
  /// Phase ACADEMIC TRANSITION SAFETY Part 6 — back-relation for the
  /// StudentAcademicRecord.promotedById FK. One row per (student, run).
  promotionsRun       StudentAcademicRecord[] @relation("PromotionRunBy")
  resultsCreated      Result[]       @relation("ResultCreatedBy")
  resultsUpdated      Result[]       @relation("ResultUpdatedBy")
  paymentsCreated     Payment[]      @relation("PaymentCreatedBy")
  paymentsUpdated     Payment[]      @relation("PaymentUpdatedBy")
  platformAuditEvents PlatformAuditEvent[] @relation("PlatformAuditActor")
  subscriptionsCreated SchoolSubscription[] @relation("SubscriptionCreatedBy")
  notifications        Notification[]
  sessions             Session[]
  // Phase 23 back-relations
  invitationsSent      UserInvitation[]      @relation("InvitationInvitedBy")
  guardianProfile      Guardian[]            @relation("GuardianUser")
  supportNotesAuthored SupportNote[]         @relation("SupportNoteAuthor")
  announcementsPublished PlatformAnnouncement[] @relation("AnnouncementPublishedBy")
  announcementDismissals AnnouncementDismissal[] @relation("AnnouncementDismisser")
  exportsRequested     DataExportRun[]       @relation("ExportRequestedBy")
  importsRequested     ImportRun[]           @relation("ImportRequestedBy")
  // CDC continuous-evaluation audit back-relations (Session 3). Named
  // explicitly because ContinuousRecord and ContinuousRecordHistory
  // each carry two FKs into User (createdBy/updatedBy and changedBy).
  continuousRecordsCreated ContinuousRecord[]        @relation("ContinuousRecordCreatedBy")
  continuousRecordsUpdated ContinuousRecord[]        @relation("ContinuousRecordUpdatedBy")
  continuousRecordHistory  ContinuousRecordHistory[] @relation("ContinuousRecordHistoryChangedBy")
  // CDC portfolio-item audit back-relations (Session 4).
  portfolioItemsCreated    PortfolioItem[]           @relation("PortfolioItemCreatedBy")
  portfolioItemsUpdated    PortfolioItem[]           @relation("PortfolioItemUpdatedBy")
  portfolioItemHistory     PortfolioItemHistory[]    @relation("PortfolioItemHistoryChangedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([schoolId, role])
  @@map("users")
}

// -----------------------------------------------------------------------------
// Domain profiles
// -----------------------------------------------------------------------------

model Student {
  id        String @id @default(uuid()) @db.Uuid
  firstName String
  lastName  String

  /// Nepal-style Symbol / Roll number. Unique within a school when present;
  /// NULL is allowed so legacy rows stay valid until one is assigned.
  symbolNumber String? @db.VarChar(40)

  /// Permanent platform-wide-unique registration number generated
  /// once at admission. Format: SCHOOLCODE-YYYY-CLASS-SERIAL
  /// (e.g. SCH0001-2026-08-0001, SCH0001-2026-NUR-0001).
  /// Components:
  ///   • SCHOOLCODE — School.schoolCode with dashes stripped
  ///   • YYYY        — admission year (admissionDate ?? createdAt)
  ///   • CLASS       — normalized admitted-class code:
  ///                   numeric grades → 2-digit zero-pad ("01"…"12"),
  ///                   named ("Nursery"→"NUR", "LKG"→"LKG", …),
  ///                   fallback → first 3 alphanumeric uppercase chars.
  ///   • SERIAL      — 4-digit zero-padded sequence per
  ///                   (school, year, class) bucket.
  ///
  /// IMMUTABLE after creation: never reassigned on promotion,
  /// section transfer, or class re-enrollment — it reflects the
  /// student's ORIGINAL admission, not their current grade.
  /// Nullable for two reasons: (a) legacy rows that pre-date
  /// admission may not have a class to derive from, (b) students
  /// whose `classId` is null at creation time can't be encoded.
  registrationNumber String? @unique @db.VarChar(60)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Optional — young students may not yet have login accounts.
  userId String? @unique @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Optional — students live "in" the school before being assigned to a class.
  // A student can be linked to a class directly when that class has no
  // sections (small schools often skip sections entirely). When a section
  // is set, its classId must equal this student's classId — the service
  // enforces that invariant on create/update.
  classId String? @db.Uuid
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  sectionId String?  @db.Uuid
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  // Demographic + contact essentials required by every real school.
  // gender / dateOfBirth / parentName / contactNumber are NOT NULL and
  // enforced by the DTO layer; the migration backfills sensible
  // placeholders for any rows that pre-date this change.
  gender         Gender
  dateOfBirth    DateTime  @db.Date
  parentName     String    @db.VarChar(120)
  contactNumber  String    @db.VarChar(40)
  /// Optional postal / street address — free-form so it accommodates
  /// any country's format.
  address        String?
  /// Optional admission date — defaults to row createdAt for legacy
  /// rows, but the form lets admins set the real value when known.
  admissionDate  DateTime? @db.Date

  attendance     Attendance[]
  results        Result[]
  feeAssignments FeeAssignment[]
  payments       Payment[]
  academicRecords StudentAcademicRecord[]
  // Phase 23 — guardian linking foundations.
  guardianLinks  StudentGuardianLink[]
  // CDC continuous-evaluation write surface (Session 3).
  continuousRecords ContinuousRecord[]
  // CDC portfolio-item write surface (Session 4).
  portfolioItems    PortfolioItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft-delete archive fields (Phase data-lifecycle).
  ///
  ///   • `archivedAt` is the sentinel — when set, every default
  ///     listing query filters this row out. The UI's "Archived"
  ///     tab passes `includeArchived=true` to opt back in.
  ///   • `archivedById` is the operator who archived for the audit
  ///     trail (`SetNull` on User delete so audit history survives).
  ///   • `archiveReason` is the free-form reason captured in the
  ///     archive dialog. Persisted so the row can answer "why was
  ///     this archived" without round-tripping to the audit table.
  ///
  /// Restoration sets all three back to null (the audit trail
  /// retains the full lock-then-unlock-then-archive history).
  archivedAt    DateTime?
  archivedById  String?    @db.Uuid
  archivedBy    User?      @relation("StudentArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  archiveReason String?    @db.VarChar(500)

  @@unique([schoolId, symbolNumber])
  @@index([schoolId])
  @@index([classId])
  @@index([sectionId])
  // Tenant-scoped lookup by registration number — used by the
  // student search endpoint and the global search bar.
  @@index([schoolId, registrationNumber])
  /// Composite for the default "non-archived first" listing.
  @@index([schoolId, archivedAt])
  @@map("students")
}

// -----------------------------------------------------------------------------
// Academic hierarchy
// -----------------------------------------------------------------------------

model Class {
  id   String @id @default(uuid()) @db.Uuid
  name String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  sections            Section[]
  students            Student[]
  // `teachers` back-relation removed: the legacy Teacher.classId FK
  // was dropped in 20260511. Teacher → Class is reachable only via
  // TeachingAssignment.classId now.
  teachingAssignments TeachingAssignment[]
  feeStructures       FeeStructure[]
  academicRecords     StudentAcademicRecord[]
  /// Phase ACADEMIC TRANSITION SAFETY Part 6 — back-relation for the
  /// "promoted into this class" pointer on StudentAcademicRecord.
  promotionTargets    StudentAcademicRecord[] @relation("PromotionNextClass")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("classes")
}

model Section {
  id   String @id @default(uuid()) @db.Uuid
  name String

  classId String @db.Uuid
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  students            Student[]
  // `teachers` back-relation removed: the legacy Teacher.sectionId FK
  // was dropped in 20260511. Teacher → Section is reachable only via
  // TeachingAssignment.sectionId now.
  teachingAssignments TeachingAssignment[]
  academicRecords     StudentAcademicRecord[]
  /// Phase ACADEMIC TRANSITION SAFETY Part 6 — back-relation for
  /// SAR.nextSectionId.
  promotionTargets    StudentAcademicRecord[] @relation("PromotionNextSection")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, name])
  @@index([classId])
  @@map("sections")
}

// -----------------------------------------------------------------------------
// Attendance
// -----------------------------------------------------------------------------

model Attendance {
  id     String           @id @default(uuid()) @db.Uuid
  date   DateTime         @db.Date
  status AttendanceStatus

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Denormalized for fast tenant-scoped queries; kept in sync by the service.
  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// Academic session — defaults to the active session at write
  /// time. Reports filter by this when comparing year-over-year.
  sessionId String?          @db.Uuid
  session   AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@index([schoolId, sessionId, date])
  @@map("attendance")
}

// -----------------------------------------------------------------------------
// Exams + Results (NEB grading system)
// -----------------------------------------------------------------------------

model Exam {
  id   String @id @default(uuid()) @db.Uuid
  name String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  subjects ExamSubject[]
  results  Result[]

  /// Audit. Same nullable + SetNull pattern as Subject — see comment
  /// on Subject for the reasoning.
  createdById String? @db.Uuid
  createdBy   User?   @relation("ExamCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String? @db.Uuid
  updatedBy   User?   @relation("ExamUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  /// Academic session this exam belongs to. Nullable: existing rows
  /// from before the session feature have no session attached. New
  /// writes default to the active session; SetNull on session delete
  /// so removing a session detaches its exams instead of cascading.
  sessionId String?         @db.Uuid
  session   AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  /// Marks-publication lock. When true, every Result write path
  /// (results.save / bulkSave / gridSave) rejects with HTTP 423
  /// LOCKED. Toggled by school ADMINs via the `/exams/:id/lock` and
  /// `/exams/:id/unlock` endpoints. Defaults to false so existing
  /// rows stay editable until an operator explicitly publishes.
  ///
  /// `lockedAt` and `lockedById` are the audit context — preserved
  /// even after a subsequent unlock so the marksheet UI can still
  /// render "Locked by X on Jan 15 at 10:42, unlocked by Y at …"
  /// from a single row's history (cross-checked against the
  /// PlatformAuditEvent stream).
  locked     Boolean   @default(false)
  lockedAt   DateTime?
  lockedById String?   @db.Uuid
  lockedBy   User?     @relation("ExamLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)

  /// Phase ACADEMIC TRANSITION SAFETY Part 4 — publication state.
  /// `publishedAt` non-null means the exam's marks are visible on
  /// parent-facing marksheets. Orthogonal to the lock flag: a
  /// published exam can still be unlocked for edits, and a locked
  /// exam need not be published (rare but legal). The three
  /// surfaceable states map as:
  ///   Draft     — publishedAt IS NULL  AND locked = false
  ///   Published — publishedAt IS NOT NULL AND locked = false
  ///   Locked    — locked = true (regardless of publishedAt)
  /// `publishedById` snapshots the actor for the audit-trail tooltip.
  publishedAt   DateTime?
  publishedById String?   @db.Uuid
  publishedBy   User?     @relation("ExamPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)

  /// Soft-delete archive fields — same shape and semantics as
  /// Student.archived* (see comment there). Archived exams are
  /// hidden from default listings + pickers; the Result rows stay
  /// in the DB so historical marksheets remain printable.
  ///
  /// Writes are also blocked: `assertEditable` on this exam throws
  /// HTTP 410 GONE when archivedAt is set (distinct from the 423
  /// LOCKED path for `locked = true` — locking is reversible from
  /// the marksheet toolbar; archiving requires the dedicated
  /// archive/restore endpoint).
  archivedAt    DateTime?
  archivedById  String?    @db.Uuid
  archivedBy    User?      @relation("ExamArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  archiveReason String?    @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([schoolId, sessionId])
  @@index([schoolId, archivedAt])
  @@map("exams")
}

model ExamSubject {
  id   String @id @default(uuid()) @db.Uuid
  name String
  /// Theory component full marks. Required; defaults to 100 for backward compat.
  theoryFullMarks Int @default(100)
  /// Practical component full marks. 0 means this subject has no practical
  /// (theory-only) and the pass rule auto-passes practical.
  practicalFullMarks Int @default(0)
  /// Credit hours for this subject (CDC weekly-period weighting).
  /// Used to compute the credit-hour-weighted GPA per the CDC progress
  /// report formula:  GPA = Σ(gradePoint × creditHours) / Σ(creditHours).
  /// Default of 5 matches the most common weekly allocation, so all
  /// existing rows remain valid without a data migration.
  creditHours Float @default(5)

  examId String @db.Uuid
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  results Result[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, name])
  @@index([examId])
  @@map("exam_subjects")
}

/// One record per (student, subject). Grade data is derived from `marks`
/// server-side via GradingService and stored denormalized for fast reads.
model Result {
  id String @id @default(uuid()) @db.Uuid

  examId String @db.Uuid
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId String      @db.Uuid
  subject   ExamSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  theoryMarks    Float @default(0)
  practicalMarks Float @default(0)
  percentage     Float
  letterGrade    LetterGrade
  gradePoint     Float

  /// Marked-absent flag for bulk grid entry. When true, the student
  /// did not appear for this subject — marks are forced to 0 and the
  /// computed letter grade is NG (NEB rule: failing to appear = NG).
  /// Defaults to false so every existing row stays valid; the column
  /// was added in 20260512 for the marks-entry grid.
  absent Boolean @default(false)

  /// Audit. Particularly useful for results since they're often
  /// disputed — knowing which teacher / staff / admin entered or
  /// last edited a mark is important for compliance.
  createdById String? @db.Uuid
  createdBy   User?   @relation("ResultCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String? @db.Uuid
  updatedBy   User?   @relation("ResultUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  /// Academic session — denormalized from the parent Exam so result
  /// queries can filter by session without a join. Set to the exam's
  /// session at insert time; left untouched on later edits.
  sessionId String?          @db.Uuid
  session   AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId])
  @@index([examId])
  @@index([studentId])
  @@index([sessionId])
  @@map("results")
}

model Teacher {
  id   String @id @default(uuid()) @db.Uuid
  name String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// REQUIRED — every Teacher must be linked to a User. The dashboard
  /// resolves a teacher's assignments via Teacher.userId === user.id,
  /// so a userId-less row is unreachable from the teacher's POV.
  /// Enforced at the API layer (createWithUser is the only allowed
  /// path) AND at the DB layer (NOT NULL + cascade on user delete).
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Source of truth for what the teacher can act on. Each row pairs
  /// the teacher with a (class, optional section, optional subject).
  /// A teacher can have many — covering multiple classes and/or
  /// multiple subjects.
  ///
  /// NOTE: the legacy `classId` / `sectionId` columns that used to
  /// live on this row were removed in 20260511 — TeachingAssignment
  /// is the only place that information lives now.
  assignments TeachingAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@map("teachers")
}

// -----------------------------------------------------------------------------
// Teaching assignments (multi-class / multi-subject)
// -----------------------------------------------------------------------------

/// School-owned subject catalog (Math, Science, English, ...). Subjects
/// are referenced by `TeachingAssignment.subjectId` to express "this
/// teacher teaches Math to Class 8" rather than "this teacher teaches
/// Class 8" alone.
///
/// `ExamSubject` (per-exam subject row with full marks) does NOT yet
/// link to this table — that's a separate migration. For now Subject is
/// only used by TeachingAssignment.
model Subject {
  id   String @id @default(uuid()) @db.Uuid
  name String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  teachingAssignments TeachingAssignment[]

  /// Audit: who originally created this row + who last touched it.
  /// Both nullable: existing rows from before this migration have
  /// no creator on file, and we'd rather keep the row than fabricate
  /// one. SetNull on user delete so removing a teacher/admin doesn't
  /// nuke the subject they once created.
  createdById String? @db.Uuid
  createdBy   User?   @relation("SubjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String? @db.Uuid
  updatedBy   User?   @relation("SubjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}

/// One row per "this teacher can act on this (class, optional section,
/// optional subject)". A teacher with multiple rows covers multiple
/// classes/subjects — exactly the multi-class case the legacy single
/// `Teacher.classId/sectionId` couldn't express.
///
/// Coverage rules used by TeacherScopeService:
///   • sectionId set  → assignment covers ONLY that section
///   • sectionId null → assignment covers the WHOLE class (every
///     section under it + students linked directly to the class)
///   • subjectId set  → required for exam writes (saveResults) on this
///     class. Attendance writes ignore subjectId — they only check class.
///   • subjectId null → "any subject" / "no subject" — used for class
///     teachers, who own attendance but not necessarily a subject.
model TeachingAssignment {
  id String @id @default(uuid()) @db.Uuid

  teacherId String  @db.Uuid
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  classId String @db.Uuid
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  sectionId String?  @db.Uuid
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  subjectId String?  @db.Uuid
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  /// Denormalized for fast tenant-scoped queries + cross-tenant safety.
  /// Always equal to the teacher's schoolId; the service writes both.
  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Postgres treats NULLs as DISTINCT in unique indexes, so duplicate
  /// (teacher, class, NULL section, NULL subject) rows are technically
  /// allowed by this constraint. The service-level guard rejects any
  /// duplicate before insert; this index just protects against truly
  /// identical non-null tuples.
  @@unique([teacherId, classId, sectionId, subjectId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([classId])
  @@index([sectionId])
  @@index([subjectId])
  @@map("teaching_assignments")
}

// -----------------------------------------------------------------------------
// Fees
// -----------------------------------------------------------------------------

model FeeStructure {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  amount    Float
  frequency FeeFrequency

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// Optional class scope. When set, this fee only applies to students
  /// assigned to that class — assigning to any other student is rejected
  /// in the service layer. Null means "applies to any class" (a general
  /// school-wide fee).
  classId String? @db.Uuid
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  assignments FeeAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([classId])
  @@map("fee_structures")
}

model FeeAssignment {
  id String @id @default(uuid()) @db.Uuid
  /// Amount snapshot captured at assignment time. Changes to the parent
  /// FeeStructure do NOT retroactively affect already-assigned fees.
  /// This is the BASE amount — the final amount owed after any discount
  /// is computed as `amount - (PERCENT? amount*value/100 : value)`.
  amount  Float
  dueDate DateTime @db.Date

  /// Scholarship / discount for this specific assignment. Null = no
  /// discount. `discountValue` is a percentage (0–100) when type is
  /// PERCENT, or a currency amount when type is FIXED. The final due
  /// amount is clamped to 0 at the service layer so negative dues are
  /// impossible.
  discountType  DiscountType?
  discountValue Float?

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  feeStructureId String       @db.Uuid
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([dueDate])
  @@map("fee_assignments")
}

enum DiscountType {
  PERCENT
  FIXED
}

model Payment {
  id     String   @id @default(uuid()) @db.Uuid
  amount Float
  date   DateTime @db.Date

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /// Optional link to a specific assignment. Unlinked payments count as a
  /// general credit against the student's total due.
  feeAssignmentId String?        @db.Uuid
  feeAssignment   FeeAssignment? @relation(fields: [feeAssignmentId], references: [id], onDelete: SetNull)

  /// Auto-generated RCPT-YYYY-NNNN. Nullable for pre-receipt-system payments;
  /// unique within a school.
  receiptNumber String? @db.VarChar(40)
  /// Free-form note attached to the receipt (e.g. "Paid in cash by parent").
  notes  String?
  /// How the payment was made. Optional — not every record carries this detail.
  method PaymentMethod?

  /// Lifecycle status — explicit so refund flows mark the source row,
  /// not just rely on the existence of a back-link. VOID is reserved
  /// for future "cancel before reconciliation" flows.
  status PaymentStatus @default(ACTIVE)

  /// When this row is a refund, points back at the original payment it
  /// reverses. The refund itself is stored as a separate row with
  /// negative `amount` so the audit history stays append-only — the
  /// original receipt remains untouched and a new FR-…-R receipt
  /// number is issued for the refund slip.
  refundOfPaymentId String?  @unique @db.Uuid
  refundOf          Payment? @relation("PaymentRefund", fields: [refundOfPaymentId], references: [id], onDelete: SetNull)
  refundedBy        Payment? @relation("PaymentRefund")

  /// Required for refund rows; null on regular payments. Captures WHY
  /// the refund happened — auditors will ask, and the operator's
  /// memory will fail.
  refundReason String?

  /// Caller-supplied idempotency key. Two POST /payments calls with the
  /// same `(schoolId, clientRequestId)` resolve to the same Payment row.
  /// Optional so legacy callers without an idempotency key still work.
  clientRequestId String? @db.Uuid

  /// Audit: the cashier (User row) who originally recorded this
  /// payment. Surfaces on the receipt as "Received by …" and on the
  /// global Payment History table. Nullable for legacy rows that
  /// pre-date this column; ON DELETE SET NULL preserves the payment
  /// row if the user is later removed.
  createdById String? @db.Uuid
  createdBy   User?   @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  /// Audit: most recent editor of the row's mutable annotations
  /// (notes / method via PATCH /payments/:id). Frozen fields like
  /// amount / receiptNumber are NEVER touched by an edit, but the
  /// updatedById flips so the trail still reflects who annotated.
  updatedById String? @db.Uuid
  updatedBy   User?   @relation("PaymentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, receiptNumber])
  @@unique([schoolId, clientRequestId])
  @@index([schoolId])
  @@index([studentId])
  @@index([feeAssignmentId])
  @@index([status])
  @@index([createdById])
  @@map("payments")
}

/// Lifecycle status of a payment row.
///   ACTIVE   — the payment counts toward the student's balance.
///   REFUNDED — the payment was reversed via `POST /payments/:id/refund`.
///              The reversal is its own row with negative amount; this
///              flag flips on the source row so dashboards and reports
///              can see "this was undone" without joining the refund
///              back-link.
///   VOID     — reserved. Not currently set by any code path; here for
///              future "cancel before posting" flows.
enum PaymentStatus {
  ACTIVE
  REFUNDED
  VOID
}

// -----------------------------------------------------------------------------
// Platform audit log
// -----------------------------------------------------------------------------

/// Append-only log of every platform-level write (Phase 8).
///
/// Schema is intentionally generic so a new platform action type
/// only needs a new `PlatformAuditAction` enum value — never a new
/// table column. `before` / `after` JSON snapshots store the
/// minimal slice of the target row that changed, not the whole row;
/// keeps the audit narrow + privacy-respecting.
///
/// `actorUserId` is `NOT NULL` even though the FK constraint is
/// declared `SetNull` — Postgres will reject a delete of a user who
/// has audit rows. That's intentional: removing an actor whose
/// actions are still in the trail would orphan history. Phase 9 may
/// relax this if the spec needs to support user removal.
model PlatformAuditEvent {
  id            String              @id @default(uuid()) @db.Uuid
  action        PlatformAuditAction
  /// Tenant scope, denormalized for the school-side audit feed.
  /// Populated whenever the action pertains to a specific school —
  /// SCHOOL_CODE_ASSIGNED, MARKS_LOCKED, ATTENDANCE_BULK_OVERWRITE, …
  /// Nullable for actions that don't have a school anchor (e.g.
  /// future platform-only events). The Operations Center continues
  /// to query without this filter; school admins query WITH it via
  /// `/audit/recent`.
  schoolId      String?             @db.Uuid
  /// User who performed the action — typically a SUPER_ADMIN. Email
  /// + role are denormalized snapshots so deleting/renaming the
  /// actor later doesn't rewrite history.
  actorUserId   String              @db.Uuid
  actor         User                @relation("PlatformAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail    String?
  actorRole     String?
  /// What was acted upon. `targetType` is a free-form tag
  /// ("SCHOOL", "USER", "SUBSCRIPTION") not enforced as an enum —
  /// it grows as new actions land and we don't want a coupled
  /// migration every time. `targetLabel` is a human-readable
  /// snapshot (e.g. the school name) so the audit row is readable
  /// even if the target is later renamed or deleted.
  targetType    String
  targetId      String              @db.Uuid
  targetLabel   String?
  /// JSON snapshots of the relevant slice. Keep narrow.
  before        Json?
  after         Json?
  /// Free-form audit reason captured at the call site (required for
  /// destructive actions like SCHOOL_STATUS_CHANGED → SUSPENDED).
  reason        String?
  /// Best-effort capture of network context.
  ip            String?
  userAgent     String?
  /// Phase 22 — request correlation id (when the action ran inside
  /// an HTTP request). Lets ops trace an event back to the originating
  /// request line in the structured log stream.
  correlationId String?
  createdAt     DateTime            @default(now())

  @@index([action])
  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt(sort: Desc)])
  @@index([correlationId])
  /// Composite for the school-side audit feed — newest-first per
  /// tenant. The query at /audit/recent always passes (schoolId)
  /// + ORDER BY createdAt DESC LIMIT N, so this index serves it in
  /// one btree scan.
  @@index([schoolId, createdAt(sort: Desc)])
  @@map("platform_audit_events")
}

// -----------------------------------------------------------------------------
// School subscriptions
// -----------------------------------------------------------------------------

/// Append-only subscription history per school. The "current"
/// subscription is the most recent row by createdAt where the
/// endDate is in the future (or NULL for UNLIMITED).
///
/// Why append-only:
///   • Every plan change / renewal / extension is its own row, so
///     the audit trail naturally reflects the lifecycle without
///     needing version columns or change-tracking. The corresponding
///     SUBSCRIPTION_CREATED audit event captures the actor + reason.
///   • Old rows are never edited — that means a future PDF receipt
///     for "what plan did this school have on date X?" is just a
///     range query.
///
/// Status integration:
///   • Creating a TRIAL subscription sets `school.status = TRIAL`
///     and `school.expiresAt = endDate`.
///   • Creating any other plan whose endDate is in the future flips
///     the school back to ACTIVE (unless SUSPENDED — the operator
///     must explicitly reactivate suspended schools).
///   • `school.expiresAt` is the denormalized cache of the current
///     subscription's `endDate`. Reads use it; writes update it.
model SchoolSubscription {
  id              String           @id @default(uuid()) @db.Uuid
  schoolId        String           @db.Uuid
  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan
  billingCycle    BillingCycle
  startDate       DateTime
  /// Null only for UNLIMITED plans. For all other tiers, the
  /// service computes startDate + cycle if the operator doesn't
  /// pass an explicit value.
  endDate         DateTime?
  /// Null = unlimited. Phase 5 will enforce on writes; today these
  /// drive the "X of Y students" indicator on the platform UI.
  studentLimit    Int?
  teacherLimit    Int?
  /// Per-feature flags (Phase 5 enforcement). Default `{}` means
  /// "no overrides; baseline schoolwide-defaults apply."
  enabledFeatures Json             @default("{}")
  /// Free-form note captured at create time. Used by the platform
  /// owner to record "Renewed early at parent's request" or
  /// "Refunded last cycle, this is the replacement period".
  notes           String?

  createdById     String?          @db.Uuid
  createdBy       User?            @relation("SubscriptionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([schoolId, createdAt(sort: Desc)])
  @@map("school_subscriptions")
}

// -----------------------------------------------------------------------------
// Announcements
// -----------------------------------------------------------------------------

/// School-wide announcement posted by an admin and visible to every
/// authenticated user in that school. Intentionally minimal —
/// title + body + timestamp — so the feature ships small and grows
/// later (audience scoping, attachments, expiry, etc.).
model Announcement {
  id      String @id @default(uuid()) @db.Uuid
  title   String @db.VarChar(160)
  /// Body text. No length cap at the DB level; the DTO enforces a
  /// reasonable max so the UI doesn't have to render walls of text.
  message String

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  /// Optional session scope. Many announcements span sessions
  /// ("Welcome back!" in early-year etc.) so this is purely a
  /// classifier — the announcements feed doesn't filter on it by
  /// default. Defaults to the active session at write time.
  sessionId String?          @db.Uuid
  session   AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Listed newest-first; the (schoolId, createdAt) pair makes the
  // tenant-scoped feed query an index-only seek-and-scan.
  @@index([schoolId, createdAt])
  @@index([schoolId, sessionId])
  @@map("announcements")
}

// -----------------------------------------------------------------------------
// Academic sessions (multi-year support)
// -----------------------------------------------------------------------------

/// One academic year per school. Drives report scoping and the
/// promotion workflow. The "active" flag is the school's current
/// session — exactly one row per school can have it set, enforced by
/// a partial unique index in the migration.
///
/// Existing rows on the four target tables (Exam, Result, Attendance,
/// Announcement) carry sessionId = NULL until explicitly assigned
/// — the queries that filter by session treat NULL as "any session"
/// to keep legacy data visible during the transition.
model AcademicSession {
  id        String   @id @default(uuid()) @db.Uuid
  /// Display label — e.g. "2082/83" or "2024-25". Unique per school.
  name      String   @db.VarChar(40)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean  @default(false)

  /// When true, the session is read-only: attendance writes,
  /// marks updates, and exam edits/creates all reject. Lock is
  /// the precondition for running promotion — admins lock the
  /// year, double-check the books, then run promotion to roll
  /// students into the next session.
  isLocked  Boolean  @default(false)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Children — back-relations for the tables that gain a sessionId.
  // SetNull on session delete (defined on the FK side) for the
  // historical records; cascade for the academic records (those are
  // session-shaped data, no point keeping orphans).
  exams           Exam[]
  results         Result[]
  attendance      Attendance[]
  announcements   Announcement[]
  academicRecords StudentAcademicRecord[]
  // CDC continuous-evaluation write surface (Session 3).
  continuousRecords ContinuousRecord[]
  // CDC portfolio-item write surface (Session 4).
  portfolioItems    PortfolioItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([schoolId, isActive])
  @@map("academic_sessions")
}

// -----------------------------------------------------------------------------
// Sessions (Phase 17 follow-up)
// -----------------------------------------------------------------------------

/// One row per issued JWT. The token's `sid` claim points back here;
/// JwtStrategy looks up the row on every request, rejects revoked
/// tokens, and throttle-touches `lastActiveAt`.
///
/// Distinct from `users.tokensValidAfter`:
///   • Watermark is the "kill all" hammer (operator-grade incident
///     response). Phase 9.
///   • Sessions are per-token (user-grade "log out my old laptop").
///     Phase 17 follow-up.
/// Both coexist; the strategy honors both.
///
/// Backwards compatibility:
///   Tokens issued before this model existed have no `sid` claim.
///   The strategy treats them as implicit sessions and falls through
///   to the watermark check alone. Once those tokens expire (default
///   7d), every active token has a sid.
model Session {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  /// Throttle-updated by the JWT strategy on each authenticated
  /// request. Capped at one write per minute per session to avoid
  /// write amplification.
  lastActiveAt  DateTime  @default(now())
  /// Snapshotted at creation, NOT live — IP / UA can change as the
  /// session moves networks; the snapshot answers "where did this
  /// session originally come from?"
  ip            String?
  userAgent     String?
  /// Phase 22 — coarse device fingerprint (SHA-256 of UA + IP-prefix
  /// + accept-language). Stable across the life of a session under
  /// the same browser, changes when the user moves to a new device
  /// or rolls IP into a different /24. New-device-detection compares
  /// this against the user's recent fingerprints and surfaces a
  /// "New device detected" notification when no recent match.
  deviceFingerprint String?
  /// Phase 22 — last-observed IP / user-agent (vs. the snapshot
  /// above which is creation-time only). Lets ops see "this session
  /// moved networks" patterns. Updated on the same throttle cadence
  /// as `lastActiveAt`.
  lastIp        String?
  lastUserAgent String?
  /// Null while active. Once set, the strategy rejects the token;
  /// the row stays for audit history.
  revokedAt     DateTime?
  revokedReason String?

  @@index([userId, lastActiveAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([deviceFingerprint])
  @@map("sessions")
}

// -----------------------------------------------------------------------------
// Notifications (Phase 2 maturity)
// -----------------------------------------------------------------------------

/// One row per logical notification event. Channel-agnostic: the
/// `deliveries` back-relation captures which channels were attempted
/// + the outcome. Templates live in TypeScript modules; `templateKey`
/// is the stable code-side identifier the renderer looks up.
///
/// Idempotency: `(templateKey, dedupeKey)` is unique when both are
/// set. A producer that fires the same trigger twice resolves to the
/// same Notification row + the existing deliveries.
model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  templateKey String
  schoolId    String?  @db.Uuid
  userId      String?  @db.Uuid
  payload     Json     @default("{}")
  dedupeKey   String?
  /// Phase 14 — operator-facing severity for the Notification Center.
  /// Default INFO so legacy rows / existing producers don't need to
  /// supply it. Producers SHOULD pass an explicit severity for
  /// anything beyond plain informational events.
  severity    NotificationSeverity @default(INFO)
  /// Denormalised display title — produced by the template at write
  /// time so list views skip re-rendering. Nullable for legacy rows.
  title       String?
  /// Null until the operator opens the row in the Notification
  /// Center. The bell badge counts rows where this is null.
  readAt      DateTime?
  /// Phase 22 — request correlation id from the originating HTTP
  /// request (when one exists). Lets ops cross-reference the
  /// notification back to the originating request log line.
  correlationId String?
  createdAt   DateTime @default(now())

  // Cascade on parent removal so the audit trail stays consistent
  // with the rest of the tenant's data.
  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveries NotificationDelivery[]

  @@unique([templateKey, dedupeKey])
  @@index([schoolId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([severity, createdAt(sort: Desc)])
  @@map("notifications")
}

/// One row per channel attempt against a Notification. Retries
/// create new rows — the source Notification stays untouched.
model NotificationDelivery {
  id                String                     @id @default(uuid()) @db.Uuid
  notificationId    String                     @db.Uuid
  channel           NotificationChannel
  /// Per-channel address: email for EMAIL, phone for SMS, user id
  /// for IN_APP. Snapshotted at delivery time so renaming the user's
  /// email later doesn't rewrite history.
  recipient         String
  status            NotificationDeliveryStatus @default(QUEUED)
  attempts          Int                        @default(0)
  /// Last provider error on FAILED. Truncated to 1KB at the service
  /// layer to keep audit rows compact.
  errorMessage      String?
  /// Provider message id (SES/SendGrid/Twilio) when available — lets
  /// us trace bounces + complaints back to the originating delivery.
  providerMessageId String?
  sentAt            DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([status])
  @@map("notification_deliveries")
}

// -----------------------------------------------------------------------------
// Background jobs (Phase 15 maturity)
// -----------------------------------------------------------------------------

/// One row per logical job. The runtime in-process worker reads from
/// here, advances state, retries on failure, and writes outcomes.
///
/// Persisted state means:
///   • A process restart picks up where the worker left off.
///   • Operators query the table to triage what's stuck.
///   • Idempotent producers can re-call enqueue without spamming.
///
/// (name, dedupeKey) is unique when both are set — re-enqueueing
/// the same logical work returns the existing row instead of
/// creating a duplicate.
model Job {
  id           String    @id @default(uuid()) @db.Uuid
  /// Stable handler key (e.g. "notification.send_delivery").
  /// The JobRegistry maps this to a TypeScript handler.
  name         String
  payload      Json      @default("{}")
  /// Idempotency key — combined with `name` for the unique index.
  dedupeKey    String?
  status       JobStatus @default(PENDING)
  /// When this job becomes eligible to run. Future timestamps defer
  /// execution; the worker only picks up rows whose runAt <= now().
  runAt        DateTime  @default(now())
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  /// Last error text, truncated by the service to ~1KB.
  lastError    String?
  startedAt    DateTime?
  completedAt  DateTime?
  /// Phase 22 — when the worker claimed this row. Used by the
  /// stuck-job sweeper: any RUNNING row with `lockedAt` more than
  /// JOB_STUCK_THRESHOLD_MIN minutes old is presumed orphaned by a
  /// crashed/restarted worker and gets unlocked + requeued.
  lockedAt     DateTime?
  /// Phase 22 — host:pid identifier of the worker that holds the
  /// lock. Surfaced for the operator drill-down ("which box owned
  /// the row when it stuck?"). Cleared when the row terminates.
  lockedBy     String?
  /// Phase 22 — request correlation id (when the job was scheduled
  /// inside an HTTP request). Lets ops trace a customer-reported
  /// incident from the originating request through to the job's
  /// outcome via /platform/operations/correlation/:id.
  correlationId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([name, dedupeKey])
  @@index([runAt])
  @@index([status])
  @@index([name, status])
  @@index([lockedAt])
  @@index([correlationId])
  @@map("jobs")
}

/// Per-student per-session history row. Captures the class the
/// student WAS IN during the session (snapshot at promotion time)
/// plus the outcome (promoted / retained / left). Immutable once
/// written — never edited, never deleted (cascade-on-delete only
/// kicks if the parent session/student is removed).
///
/// `(studentId, sessionId)` is unique — exactly one outcome per
/// student per academic year.
model StudentAcademicRecord {
  id String @id @default(uuid()) @db.Uuid

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  sessionId String          @db.Uuid
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// Class the student was in DURING this session. Snapshot — does
  /// NOT update if the class is later renamed (we want the historical
  /// truth, not the current display).
  classId String @db.Uuid
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  /// Optional section snapshot. Null when the school doesn't use
  /// sections or the student wasn't placed in one.
  sectionId String?  @db.Uuid
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  status StudentSessionStatus @default(PROMOTED)

  /// Credit-hour-weighted GPA captured at promotion time. Nullable so
  /// existing promotion records (written before this column existed)
  /// are unaffected. Null also means "no exam results to summarize"
  /// — promotion can run for a session that never had a final exam.
  gpa Float?
  /// Letter-grade label that pairs with `gpa` (e.g. "A+", "B", "NG").
  /// Stored as String (not the LetterGrade enum) because this is a
  /// historical snapshot — if the enum is ever extended/renamed the
  /// archived label must remain readable as-is.
  gpaLetterGrade String?
  /// Sum of credit hours used as the denominator of the weighted GPA.
  /// Stored alongside `gpa` so historical rows remain auditable even
  /// if subject credit hours are later edited.
  totalCreditHours Float?

  /// Phase ACADEMIC TRANSITION SAFETY Part 6 — historical trust.
  /// `nextClassId` snapshots the class the student was promoted INTO
  /// for this run (null for RETAINED / LEFT). Distinct from the live
  /// `Student.classId`, which may have moved again in subsequent
  /// promotion runs. Keeping the snapshot here means a five-year-old
  /// "promoted to" line still renders correctly in the history view.
  nextClassId String? @db.Uuid
  nextClass   Class?  @relation("PromotionNextClass", fields: [nextClassId], references: [id], onDelete: SetNull)
  /// Section the student was promoted into. Null when sections shuffle
  /// year-over-year (the typical case) or when not applicable.
  nextSectionId String?  @db.Uuid
  nextSection   Section? @relation("PromotionNextSection", fields: [nextSectionId], references: [id], onDelete: SetNull)
  /// User (ADMIN) who ran the promotion that produced this row.
  /// Nullable so existing rows from before this phase are unaffected;
  /// SetNull on user delete so an admin departure doesn't bubble FK
  /// constraint errors during user-archive workflows.
  promotedById String? @db.Uuid
  promotedBy   User?   @relation("PromotionRunBy", fields: [promotedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sessionId])
  @@index([sessionId])
  @@index([classId])
  @@index([schoolId])
  /// Session 5 — promote the index that migration
  /// 20260715000000_promotion_safety_publish_state created at the SQL
  /// level into the schema, so schema + migrations + dev DB agree. The
  /// index speeds up promotion-history reads that filter by the actor
  /// (audit feed). A separate Session 5 migration creates it on dev
  /// DBs that never had it.
  @@index([promotedById])
  @@map("student_academic_records")
}

// -----------------------------------------------------------------------------
// Platform incidents (Phase 22 — operator broadcast persistence)
// -----------------------------------------------------------------------------

/// Severity tier for operator-broadcast incidents. Mirrors the
/// notification severity scale but is its own enum because incidents
/// are a distinct concept (a discrete operational event with
/// active/resolved lifecycle) — not all severities map cleanly across.
enum IncidentSeverity {
  INFO
  WARNING
  CRITICAL
}

enum IncidentStatus {
  ACTIVE
  RESOLVED
}

/// Targeting scope. ALL_SCHOOLS broadcasts to every active tenant;
/// SPECIFIC_SCHOOLS broadcasts to only those listed in `targetSchoolIds`.
/// Stored as an enum (not a boolean) so future scopes (e.g. by plan
/// tier, by region) can extend cleanly.
enum IncidentScope {
  ALL_SCHOOLS
  SPECIFIC_SCHOOLS
}

/// Phase 22 — operator-broadcast incidents. Replaces the in-memory
/// active-set the Operations Center previously used.
///
/// Why a dedicated table (vs. piggy-backing the Notification model):
///   • Persistence-across-restart is a hard requirement now —
///     incidents are infrequent + high-impact and operators can't
///     lose them when a process restarts.
///   • Lifecycle is simpler than a notification: ACTIVE → RESOLVED
///     with two timestamps. No deliveries, no severity scale that
///     changes on read. A dedicated table keeps the queries trivial.
///   • Audit-linked via `createdById` / `resolvedById` snapshots —
///     the platform_audit_events row carries the full record but
///     the foreign keys here let the cockpit page join straight to
///     the actor without crossing into the audit table.
///
/// Notification fan-out is still done at broadcast time via
/// NotificationService — those rows live in the notifications table
/// and link back to the incident via the `correlationId` column on
/// Notification (set to `incident:${id}`).
model PlatformIncident {
  id              String            @id @default(uuid()) @db.Uuid
  title           String            @db.VarChar(160)
  body            String            @db.Text
  severity        IncidentSeverity
  status          IncidentStatus    @default(ACTIVE)
  targetScope     IncidentScope
  /// Array of school UUIDs when scope === SPECIFIC_SCHOOLS. Stored
  /// as Json (not String[]) for forward compatibility — future
  /// scopes may store object payloads here. Null when scope === ALL_SCHOOLS.
  targetSchoolIds Json?
  /// Operator who broadcast — kept as denormalised id (not FK) so
  /// the row survives operator deletion. The corresponding audit
  /// event holds the email + role snapshot.
  createdById     String            @db.Uuid
  /// Set when an operator marks the incident RESOLVED. Null while
  /// active.
  resolvedById    String?           @db.Uuid
  resolvedAt      DateTime?
  /// Best-effort fan-out counters captured at broadcast time. Used
  /// by the cockpit "↪ N in-app · N email" caption. Not authoritative
  /// — the Notification table is the source of truth for what was
  /// actually queued.
  inAppFanOut     Int               @default(0)
  emailFanOut     Int               @default(0)
  /// Phase 22 — request correlation id from the broadcast request,
  /// matching the same id stamped on every fan-out Notification row.
  correlationId   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([severity, createdAt(sort: Desc)])
  @@index([correlationId])
  @@map("platform_incidents")
}

// -----------------------------------------------------------------------------
// User invitations (Phase 23 — Section 2)
// -----------------------------------------------------------------------------

/// One-shot invitation token. Admin invites a teacher; recipient
/// follows the email link, sets a password, and the account
/// activates as a real `User` row. Until acceptance, the row is
/// JUST an invitation — the user has no login.
model UserInvitation {
  id             String    @id @default(uuid()) @db.Uuid
  schoolId       String    @db.Uuid
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  email          String    @db.VarChar(180)
  role           Role
  /// Opaque token in the email link. Indexed for fast accept-endpoint
  /// lookup; treat as a secret (never log full value).
  token          String    @unique @db.VarChar(80)
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  invitedById    String    @db.Uuid
  invitedBy      User      @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedUserId String?   @db.Uuid
  displayName    String?   @db.VarChar(180)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([expiresAt])
  @@map("user_invitations")
}

// -----------------------------------------------------------------------------
// Guardians + linking (Phase 23 — Section 12)
// -----------------------------------------------------------------------------

model Guardian {
  id           String   @id @default(uuid()) @db.Uuid
  schoolId     String   @db.Uuid
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  /// Optional User row when the guardian has accepted a portal
  /// invitation. Null while the guardian is just a contact record.
  userId       String?  @db.Uuid
  user         User?    @relation("GuardianUser", fields: [userId], references: [id], onDelete: SetNull)
  fullName     String   @db.VarChar(180)
  email        String?  @db.VarChar(180)
  phone        String?  @db.VarChar(40)
  relationship String?  @db.VarChar(40)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  links StudentGuardianLink[]

  @@index([schoolId])
  @@index([schoolId, email])
  @@map("guardians")
}

/// Many-to-many link. A student can have multiple guardians; a
/// guardian can have multiple linked students. `isPrimary` is the
/// "include in default fan-out" flag for notification routing.
model StudentGuardianLink {
  id           String   @id @default(uuid()) @db.Uuid
  studentId    String   @db.Uuid
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardianId   String   @db.Uuid
  guardian     Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  schoolId     String   @db.Uuid
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  isPrimary    Boolean  @default(false)
  relationship String?  @db.VarChar(40)
  createdAt    DateTime @default(now())

  @@unique([studentId, guardianId])
  @@index([studentId])
  @@index([guardianId])
  @@index([schoolId])
  @@map("student_guardian_links")
}

// -----------------------------------------------------------------------------
// Support notes (Phase 23 — Section 6)
// -----------------------------------------------------------------------------

/// Internal SUPER_ADMIN-only notes pinned to a school. Append-only
/// by convention. Distinct from PlatformAuditEvent: audit rows are
/// auto-emitted; support notes are manually-entered context.
model SupportNote {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @db.Uuid
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  authorId  String   @db.Uuid
  author    User     @relation("SupportNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  /// "important" | "info" | "warning" — drives the UI tint.
  tone      String?  @db.VarChar(20)
  createdAt DateTime @default(now())

  @@index([schoolId, createdAt(sort: Desc)])
  @@map("support_notes")
}

// -----------------------------------------------------------------------------
// Platform announcements (Phase 23 — Section 7)
// -----------------------------------------------------------------------------

enum AnnouncementAudience {
  ALL_SCHOOLS
  ADMINS_ONLY
  TEACHERS_ONLY
  SPECIFIC_SCHOOLS
}

/// Operator-published release-note / announcement banner.
/// Distinct from PlatformIncident — incidents are urgent operational
/// events; announcements are routine "new feature" / "scheduled
/// maintenance" copy with per-user dismiss tracking.
model PlatformAnnouncement {
  id              String                  @id @default(uuid()) @db.Uuid
  title           String                  @db.VarChar(180)
  body            String
  tone            String                  @default("info") @db.VarChar(20)
  audience        AnnouncementAudience    @default(ALL_SCHOOLS)
  targetSchoolIds Json?
  publishedById   String                  @db.Uuid
  publishedBy     User                    @relation("AnnouncementPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  active          Boolean                 @default(true)
  linkUrl         String?                 @db.VarChar(500)
  expiresAt       DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  dismissals AnnouncementDismissal[]

  @@index([active, createdAt(sort: Desc)])
  @@map("platform_announcements")
}

model AnnouncementDismissal {
  id              String                  @id @default(uuid()) @db.Uuid
  announcementId  String                  @db.Uuid
  announcement    PlatformAnnouncement    @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId          String                  @db.Uuid
  user            User                    @relation("AnnouncementDismisser", fields: [userId], references: [id], onDelete: Cascade)
  dismissedAt     DateTime                @default(now())

  @@unique([announcementId, userId])
  @@index([userId])
  @@map("announcement_dismissals")
}

// -----------------------------------------------------------------------------
// Data exports + imports (Phase 23 — Sections 8 + 9)
// -----------------------------------------------------------------------------

enum ExportRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  EXPIRED
}

enum ImportRunStatus {
  PENDING
  VALIDATING
  RUNNING
  SUCCEEDED
  FAILED
  ROLLED_BACK
}

model DataExportRun {
  id            String          @id @default(uuid()) @db.Uuid
  schoolId      String          @db.Uuid
  school        School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  requestedById String          @db.Uuid
  requestedBy   User            @relation("ExportRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  entity        String          @db.VarChar(40)
  filters       Json            @default("{}")
  format        String          @db.VarChar(10)
  status        ExportRunStatus @default(PENDING)
  outputUrl     String?
  sizeBytes     Int?
  expiresAt     DateTime?
  errorMessage  String?
  createdAt     DateTime        @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([status])
  @@map("data_export_runs")
}

model ImportRun {
  id            String          @id @default(uuid()) @db.Uuid
  schoolId      String          @db.Uuid
  school        School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  requestedById String          @db.Uuid
  requestedBy   User            @relation("ImportRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  entity        String          @db.VarChar(40)
  filename      String          @db.VarChar(240)
  totalRows     Int             @default(0)
  validRows     Int             @default(0)
  invalidRows   Int             @default(0)
  importedRows  Int             @default(0)
  status        ImportRunStatus @default(PENDING)
  /// Per-row errors, parsed sample, inferred column mapping. The
  /// preview UI renders this before the user clicks "commit".
  dryRunSummary Json            @default("{}")
  errorMessage  String?
  createdAt     DateTime        @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([status])
  @@map("import_runs")
}

// -----------------------------------------------------------------------------
// Backups (Phase α — real backup engine)
// -----------------------------------------------------------------------------

enum BackupRunKind {
  /// Full pg_dump of the entire database. The default + safest.
  FULL
  /// Reserved for future incremental + WAL-shipping engines. Not
  /// produced in this phase; the column exists so adding either
  /// later doesn't need a migration.
  INCREMENTAL
  WAL
}

enum BackupRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  EXPIRED
}

/// One row per backup attempt. Replaces the Phase 22 in-memory stub.
/// Storage location is a free-form URL/path so we can swap providers
/// (local disk → S3 → GCS) without a schema change.
///
/// Retention:
///   `retentionUntil` is set at create time from the operator-tier
///   retention config. The cleanup sweeper purges runs whose
///   retention has passed AND whose status is SUCCEEDED — failed /
///   running rows are kept for forensics until manually cleared.
model BackupRun {
  id            String          @id @default(uuid()) @db.Uuid
  kind          BackupRunKind   @default(FULL)
  status        BackupRunStatus @default(PENDING)
  /// Storage backend identifier ("local" / "s3" / …).
  storage       String          @db.VarChar(40)
  /// Provider-specific URL or absolute filesystem path.
  location      String?
  /// Bytes on disk after compression. Null until SUCCEEDED.
  sizeBytes    BigInt?
  /// SHA-256 of the artifact for tamper detection.
  sha256        String?         @db.VarChar(64)
  /// True iff this run was scheduled by cron. False for operator-
  /// triggered ad-hoc backups.
  scheduled     Boolean         @default(true)
  /// User who triggered the run (null for cron).
  triggeredById String?         @db.Uuid
  startedAt     DateTime?
  completedAt   DateTime?
  errorMessage  String?
  /// When the cleanup sweeper is allowed to delete this row + its
  /// artifact. Defaults to 30d after creation.
  retentionUntil DateTime?
  createdAt     DateTime        @default(now())

  @@index([status, createdAt(sort: Desc)])
  @@index([retentionUntil])
  @@map("backup_runs")
}

// -----------------------------------------------------------------------------
// CDC Continuous Evaluation — learning outcomes catalogue (seed data).
// -----------------------------------------------------------------------------
//
// Sourced from the CDC विद्यार्थी मूल्याङ्कन मार्गदर्शन २०८३. Versioned by
// curriculum year (BS, e.g. "2083") so a future revision can co-exist
// without overwriting the prior year's outcomes — every school keeps
// reading the version they were trained on until the operator explicitly
// switches.
//
// Tenant scope: NONE. This is platform-global seed data, identical for
// every school in Nepal that follows the CDC curriculum. Per-tenant
// overlays (custom outcomes, teacher-defined rubrics) are deliberately
// out of scope for this foundational session and will live on a
// different model when introduced.
//
// Mutation policy: this table is INSERT-ONLY at runtime. The seed
// runner upserts new rows; nothing in the application code path edits
// existing rows. Future curriculum revisions should land as new
// `curriculumVersion` rows, not in-place edits.
//
// Feature gating: read access is gated behind the `conEvaluation`
// feature flag (FeatureFlagsGuard at controller level). See
// `backend/src/learning-outcome/learning-outcome.controller.ts`.

/// CDC continuous-evaluation learning outcome (seed data, immutable).
/// Sourced from the CDC विद्यार्थी मूल्याङ्कन मार्गदर्शन २०८३.
/// Versioned by curriculum year; never modified at runtime.
model LearningOutcome {
  id                String      @id @default(cuid())
  classLevel        Int         // 4 (will expand to 1-5 in future sessions)
  subjectCode       SubjectCode
  curriculumVersion String      @default("2083") // BS year
  unitNumber        Int
  unitTitleEn       String?
  unitTitleNp       String?
  sortOrder         Int         // position within the unit
  skillArea         SkillArea
  descriptionEn     String?
  descriptionNp     String?
  createdAt         DateTime    @default(now())

  // CDC continuous-evaluation back-relation (Session 3). LearningOutcome
  // itself stays seed-only (immutable reference data) — this is just the
  // inverse side of ContinuousRecord.outcome so Prisma can navigate.
  continuousRecords ContinuousRecord[]
  // CDC portfolio-item back-relation (Session 4). Same rationale —
  // inverse side of PortfolioItem.outcome, LearningOutcome stays
  // immutable.
  portfolioItems    PortfolioItem[]

  @@unique([classLevel, subjectCode, unitNumber, sortOrder, curriculumVersion])
  @@index([classLevel, subjectCode])
  @@index([classLevel, subjectCode, unitNumber])
  @@map("learning_outcomes")
}

enum SubjectCode {
  NEPALI
  ENGLISH
  MATHEMATICS
  SCIENCE_TECHNOLOGY
  SOCIAL_STUDIES
  HEALTH_PHYSICAL
  ARTS_EDUCATION
}

enum SkillArea {
  // Language skills (English uses 4; Nepali will use all 6 in future)
  LISTENING
  SPEAKING
  READING
  WRITING
  VOCABULARY
  LANGUAGE_STRUCTURE
  // Non-language fallback
  CONTENT_AREA
}

// ============================================================================
// CDC Continuous-evaluation WRITE side (Session 3).
//
// One ContinuousRecord per (student, outcome, session, phase). The row
// records a teacher's rating (1..4) for a student against a single CDC
// learning-outcome indicator within one academic session. Phases:
//
//   • REGULAR        — the normal classroom assessment.
//   • AFTER_SUPPORT  — re-assessment after the teacher gave extra help.
//                      Only valid when a REGULAR row exists for the
//                      same (student, outcome, session) AND that
//                      REGULAR.rating ≤ 2. The application layer
//                      enforces this precondition; the DB only
//                      enforces the (1..4) rating range via CHECK.
//
// Multi-tenant scoping: `schoolId` on every row. Reads + writes flow
// through `ContinuousRecordService`, which gates each call on the
// `conEvaluation` feature flag + `TeacherScopeService` + the active
// session's `isLocked` flag.
//
// outcomeId is a plain String (NOT @db.Uuid) because LearningOutcome.id
// is `cuid()`. Migrating that to uuid is intentionally out of scope —
// the seed layer (Sessions 1+2) is settled.
// ============================================================================
model ContinuousRecord {
  id String @id @default(uuid()) @db.Uuid

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /// FK to LearningOutcome.id. String (cuid), not @db.Uuid — see note above.
  outcomeId String
  outcome   LearningOutcome @relation(fields: [outcomeId], references: [id], onDelete: Restrict)

  sessionId String          @db.Uuid
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  phase EvalPhase

  /// Integer 1..4. Enforced at the API boundary (@IsInt @Min(1) @Max(4))
  /// AND at the DB level via the named CHECK constraint
  /// `continuous_records_rating_range_check` added by the migration.
  rating Int

  /// Optional free-text teacher remarks ("कैफियत" column in the CDC
  /// rubric). Capped soft via API validation, not the column type.
  notes String?

  /// Audit. Both nullable + onDelete: SetNull so deleting the actor
  /// keeps the row but loses the link. Mirrors the Result pattern.
  createdById String? @db.Uuid
  createdBy   User?   @relation("ContinuousRecordCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String? @db.Uuid
  updatedBy   User?   @relation("ContinuousRecordUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  /// Bumped on every successful upsert. Surfaced to clients so future
  /// bulk endpoints can implement stale-write rejection
  /// (`expectedUpdatedAt` round-trip). No DB-level lock — application
  /// layer compares the value inside the transaction.
  updatedAt DateTime @updatedAt

  history ContinuousRecordHistory[]

  @@unique([studentId, outcomeId, sessionId, phase])
  @@index([schoolId])
  @@index([sessionId])
  @@index([studentId, sessionId])
  @@map("continuous_records")
}

/// Append-only audit log for ContinuousRecord. One row per accepted
/// upsert (CREATE on first insert, UPDATE on every subsequent change).
/// Never updated or deleted from the application layer; the schema
/// has no operation to express either. Scalar fields only — no JSON
/// snapshots — so audits stay queryable.
model ContinuousRecordHistory {
  id String @id @default(uuid()) @db.Uuid

  recordId String           @db.Uuid
  record   ContinuousRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  changeKind ChangeKind

  /// State AFTER the change.
  rating Int
  phase  EvalPhase
  notes  String?

  /// State BEFORE the change. Null on CREATE rows.
  previousRating Int?
  previousNotes  String?

  changedById String? @db.Uuid
  changedBy   User?   @relation("ContinuousRecordHistoryChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  changedAt   DateTime @default(now())

  @@index([recordId])
  @@index([changedAt])
  @@map("continuous_record_history")
}

enum EvalPhase {
  REGULAR
  AFTER_SUPPORT
}

enum ChangeKind {
  CREATE
  UPDATE
}

// ============================================================================
// CDC Portfolio-item WRITE side (Session 4).
//
// One PortfolioItem per evidence artifact for a student. Lives alongside
// ContinuousRecord but is structurally simpler:
//   • No phase/two-stage progression (no AFTER_SUPPORT analogue).
//   • No DB-level rating range check (no rating at all — qualitative
//     evidence, not a scored row).
//   • No optimistic concurrency primitive (description-only edits are
//     low-contention; teachers occasionally clarify a caption hours
//     after upload, no last-write-wins risk).
//   • Append-mostly: teachers may PATCH the `description` and that's
//     it. No teacher-facing delete (a future ADMIN/SUPER_ADMIN delete
//     surface is intentionally out of scope for Session 4).
//
// Multi-tenant scope + write gates mirror ContinuousRecord exactly:
// feature flag `conEvaluation`, JWT + role guard, session lock via
// AcademicSessionService.assertSessionUnlocked, teacher scope via
// TeacherScopeService.assertPortfolioItemAccess.
//
// outcomeId is plain String? (NOT @db.Uuid) because LearningOutcome.id
// is cuid(). Same precedent as ContinuousRecord.outcomeId; matching
// the referenced PK type is required for the FK to even compile.
// ============================================================================
model PortfolioItem {
  id String @id @default(uuid()) @db.Uuid

  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String  @db.Uuid
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  sessionId String          @db.Uuid
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  /// outcomeId is plain `String?` (NOT @db.Uuid) because LearningOutcome.id
  /// uses cuid(), not uuid(). This matches the precedent set by
  /// ContinuousRecord.outcomeId. Do NOT change this to @db.Uuid even if it
  /// looks inconsistent with surrounding fields — the FK type must match
  /// the referenced primary key type exactly.
  outcomeId String?
  outcome   LearningOutcome? @relation(fields: [outcomeId], references: [id], onDelete: SetNull)

  type PortfolioItemType

  /// Free-form 1–2000 char caption / context for the artifact. Service
  /// layer trims and rejects empty-after-trim.
  description String

  /// The day this artifact represents. Service-layer validates
  /// `occurredOn ≤ today` AND `occurredOn ≥ session.startDate`.
  /// `@db.Date` strips time-of-day to keep equality checks predictable.
  occurredOn DateTime @db.Date

  /// Optional already-uploaded file URL (https://… only). File upload
  /// is out of scope for this session — callers pass a URL produced
  /// by whatever external upload pipeline they use.
  fileUrl String?

  createdById String? @db.Uuid
  createdBy   User?   @relation("PortfolioItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String? @db.Uuid
  updatedBy   User?   @relation("PortfolioItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  history PortfolioItemHistory[]

  @@index([schoolId])
  @@index([studentId, sessionId])
  @@index([sessionId])
  @@index([occurredOn])
  @@map("portfolio_items")
}

/// Append-only audit log for PortfolioItem. One row per create AND
/// one row per description edit. Scalar fields only (no JSON snapshot).
/// `previousDescription` is NULL on the create row to flag the
/// "first version" event; subsequent rows always carry the snapshot.
model PortfolioItemHistory {
  id String @id @default(uuid()) @db.Uuid

  portfolioItemId String        @db.Uuid
  portfolioItem   PortfolioItem @relation(fields: [portfolioItemId], references: [id], onDelete: Cascade)

  previousDescription String?
  newDescription      String

  changedById String? @db.Uuid
  changedBy   User?   @relation("PortfolioItemHistoryChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  changedAt DateTime @default(now())

  @@index([portfolioItemId])
  @@index([changedAt])
  @@map("portfolio_item_history")
}

enum PortfolioItemType {
  CLASS_WORK
  PROJECT
  CREATIVE
  HOMEWORK
  PRESENTATION
  OBSERVATION
}
