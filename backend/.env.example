PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://USER:PASS@HOST:5432/DATABASE?schema=public"
JWT_SECRET="generate-a-long-random-string-for-production"
JWT_EXPIRES_IN="7d"
# Comma-separated list of origins the backend's CORS layer permits.
# In development the frontend's dev script runs Next.js on port 3100
# (see frontend/package.json: "dev": "next dev -p 3100"), which is
# NOT in the hardcoded dev fallback list — set it here so a clean
# `npm run dev` works without a manual CORS patch.
# In production this is REQUIRED — boot fails fast if it is missing.
# Use the deployed frontend's https origin(s), comma-separated.
FRONTEND_URL=http://localhost:3100
